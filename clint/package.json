{
  "name": "alexkim-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "built": "concurrently \"npm run dev\" \"cd server && npm run dev\"",
    "dev": "concurrently -n \"client,server\" -c \"cyan,magenta\" \"vite\" \"node server/index.js\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "server:install": "cd server && npm install"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.4.2"
  }
}
